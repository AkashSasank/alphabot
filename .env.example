# Kite Connect API Credentials
# Get these from https://kite.zerodha.com/settings/developer/applications

# Your Kite API Key
KITE_API_KEY=your_api_key_here

# Your Kite API Secret
KITE_API_SECRET=your_api_secret_here

# Your Zerodha user ID or registered email
# This is the username/email you use to login to Kite
KITE_USER_ID=your_user_id_or_email_here

# Playwright browser settings (optional)
# Set to True to run browser in headless mode (no visual window)
# Set to False to see the browser window (default for development)
KITE_HEADLESS=False

# Login timeout in milliseconds (optional)
# Default is 45000 (45 seconds)
KITE_TIMEOUT_MS=45000

# Redirect URL base for authentication (optional)
# After successful 2FA, Kite redirects to this base URL with the request_token
# Default is http://localhost:1130/
KITE_REDIRECT_URL=http://localhost:1130/

